# Read-only Audit-Whitelist der VARIANTE 'readable' (Zelle 4, Kontrast zu
# 'locked'). Hier hat der Auditor die BERECHTIGUNG, die sudo-Policy zu LESEN --
# das ist die einzige Variable der Zelle 4. Die Policy-Dateien bleiben 0440
# (konforme Rechte); die Lesbarkeit kommt aus dieser Whitelist, NICHT aus
# welt-lesbaren Dateirechten (0644 waere selbst eine Fehlkonfiguration).
#
# DZ6: ausschliesslich lesende Befehle, exakte Pfade, kein generisches cat/less,
# kein visudo, kein Schreibrecht.
audit ALL=(root) NOPASSWD: /usr/bin/cat /etc/sudoers, /usr/bin/cat /etc/sudoers.d/10-admins
