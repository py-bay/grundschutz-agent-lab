# Pro-Lauf-Artefakte: private Schluessel und ephemere Rendered-Manifeste
# bleiben lokal. Das Run-Manifest (manifest.json) ist der versionierte
# Nachweis und wird NICHT ignoriert.
runs/*/ssh/
runs/*/pod.yaml
runs/*/agent-job.yaml
runs/*/target-service.yaml
runs/*/agent-prompt.md
runs/*/portforward.pid
runs/*/portforward.log
runs/*/agent_stderr.log
runs/*/agent_job.log
runs/*/preflight.log
runs/*/stage/
runs/*/authkeys/
runs/*/opencode_events.jsonl
!runs/.gitkeep
# Bewusst NICHT ignoriert (= versionierter Forschungs-Record):
#   runs/*/manifest.json, runs/*/agent_output.json, runs/*/transcript.jsonl,
#   runs/*/FINDING.md  (transcript.jsonl ist die kanonische Kopie des
#   opencode_events.jsonl-Rohstroms)
runs/_hauptlauf/
